# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase Client Configuration (Optional Fallback / For Cloud Synced Mode)
# Configure these keys to enable production Google Sign-In and Firestore synchronization
VITE_FIREBASE_API_KEY="YOUR_GEMINI_API_KEY_PLACEHOLDER"
VITE_FIREBASE_AUTH_DOMAIN="amplified-hexagon-zd2jw.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="amplified-hexagon-zd2jw"
VITE_FIREBASE_STORAGE_BUCKET="amplified-hexagon-zd2jw.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="321150683988"
VITE_FIREBASE_APP_ID="1:321150683988:web:d3c3c7e6bf7a33f6abd6c1"

# Supabase Configuration
# Provide these keys to switch from the local JSON database to a high-performance Supabase Postgres cloud database!
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-anon-public-key"
# Optional: Use the Service Role Key on the backend for administrative operations
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

